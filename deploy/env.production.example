# Copy to /opt/sales-quotation/shared/.env.production, fill every value, and chmod 0600.
# APP_IMAGE must be a registry digest, for example ghcr.io/owner/sales-quotation@sha256:<64 hex chars>.
APP_IMAGE=
APP_DOMAIN=
SITE_ORIGIN=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
S3_ENDPOINT=http://minio:9000
S3_REGION=
# Use a bucket-scoped MinIO application user; do not reuse the root credentials.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
AUTH_SECRET=

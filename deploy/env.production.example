# Copy to /opt/sales-quotation/shared/.env.production, set root:deploy ownership, and chmod 0640.
# Machine-safe contract: nonempty KEY=value, no export; values use A-Za-z0-9._~:/@?&=%+,- only.
# Generate secrets with: openssl rand -hex 32
# Or unpadded base64url: openssl rand -base64 48 | tr '+/' '-_' | tr -d '='
# APP_IMAGE must be a registry digest, for example ghcr.io/owner/sales-quotation@sha256:<64 hex chars>.
APP_IMAGE=
APP_DOMAIN=
SITE_ORIGIN=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=
# Backup/restore transport requires URL-safe values: letters, digits, dot, underscore, tilde, hyphen.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
S3_ENDPOINT=http://minio:9000
S3_REGION=
# Use a bucket-scoped MinIO application user; do not reuse the root credentials.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
AUTH_SECRET=
BACKUP_POLICY=required

# Backup access is separately credentialed and limited to the off-VPS backup prefix.
BACKUP_AGE_RECIPIENT=
# Restore only: uncomment with a nonempty safe path, then remove the line afterward.
# BACKUP_AGE_IDENTITY_FILE=/safe/restore/identity.txt
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=

# Copy to /opt/sales-quotation/shared/.env.production, set root:deploy ownership, and chmod 0640.
# APP_IMAGE must be a registry digest, for example ghcr.io/owner/sales-quotation@sha256:<64 hex chars>.
APP_IMAGE=
APP_DOMAIN=
SITE_ORIGIN=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=
# Backup/restore transport requires URL-safe values: letters, digits, dot, underscore, tilde, hyphen.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
S3_ENDPOINT=http://minio:9000
S3_REGION=
# Use a bucket-scoped MinIO application user; do not reuse the root credentials.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
AUTH_SECRET=

# Backup access is separately credentialed and limited to the off-VPS backup prefix.
BACKUP_AGE_RECIPIENT=
# Supply the identity file only for an approved restore; daily backup does not need it.
BACKUP_AGE_IDENTITY_FILE=
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=

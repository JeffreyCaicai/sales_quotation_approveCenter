{
  "name": "site-creator-vinext-starter",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test:unit": "vitest run",
    "test:logic": "node --experimental-strip-types --test tests/quotation.test.ts",
    "test:localization": "node --experimental-strip-types --test tests/localization.test.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts tests/*.integration.test.ts",
    "test:e2e": "playwright test tests/smoke.spec.ts",
    "check:committed-secrets": "bash scripts/check-committed-secrets.sh",
    "lint": "eslint . --ignore-pattern .next",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "imports:reconcile-pending": "tsx scripts/reconcile-pending-objects.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "bcryptjs": "^3.0.3",
    "busboy": "^1.6.0",
    "csv-parse": "^7.0.1",
    "drizzle-orm": "0.45.2",
    "fast-xml-parser": "^5.10.0",
    "file-type": "^22.0.1",
    "jose": "^6.2.3",
    "next": "16.2.6",
    "pg": "^8.22.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "xlsx": "^0.18.5",
    "yauzl": "^3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@playwright/test": "1.55.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/busboy": "^1.5.4",
    "@types/node": "22.19.19",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/yauzl": "^3.4.0",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "js-yaml": "^4.1.1",
    "tailwindcss": "4.2.1",
    "tsx": "^4.23.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  },
  "type": "module"
}
